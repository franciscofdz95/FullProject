<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <system.webServer>
    <httpProtocol>
      <customHeaders>
        <remove name="Pragma"/>
        <remove name="Cache-control"/>
        <add name="Access-Control-Allow-Origin" value="http://biaqa.inside.ups.com" xdt:Transform="Replace"/>
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>